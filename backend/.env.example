# ═══════════════════════════════════════════════════════════════
# FreightFlow Environment Configuration
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# ─── DATABASE ───────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/freightflow
PORT=5000
NODE_ENV=development

# ─── FRONTEND URL ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:5500

# ─── EMAIL CONFIGURATION (Nodemailer) ───────────────────────────
# EMAIL SERVICE STATUS: 
# - If credentials are set: Real emails will be sent
# - If credentials are empty: Mock mode (logs to console only)

# Option 1: Gmail SMTP (Recommended for Testing)
EMAIL_PROVIDER=gmail
EMAIL_USER=your-email@gmail.com
# Use App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM=your-email@gmail.com

# Option 2: Custom SMTP (Outlook, SendGrid, AWS SES)
# Uncomment and fill below to use custom SMTP provider
# EMAIL_PROVIDER=custom
# EMAIL_HOST=smtp.outlook.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@outlook.com
# EMAIL_PASSWORD=your-password
# EMAIL_FROM=your-email@outlook.com

# SendGrid Example:
# EMAIL_PROVIDER=custom
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASSWORD=SG.xxxxxxxxxxxxx
# EMAIL_FROM=noreply@yourcompany.com

# AWS SES Example:
# EMAIL_PROVIDER=custom
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USER=your-ses-username
# EMAIL_PASSWORD=your-ses-password
# EMAIL_FROM=noreply@yourcompany.com

# ─── WHATSAPP CONFIGURATION (Twilio) ────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# ─── RAZORPAY PAYMENT GATEWAY ───────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── JWT/SECURITY ───────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
SESSION_TIMEOUT=86400000

# ═══════════════════════════════════════════════════════════════
# QUICK START SETUP
# ═══════════════════════════════════════════════════════════════

# 1. GMAIL SETUP (Easiest for Testing):
#    a. Go to https://myaccount.google.com/apppasswords
#    b. Select "Mail" and "Windows Computer"  
#    c. Copy the generated 16-character password
#    d. Set EMAIL_PASSWORD above (no spaces!)
#    e. Set EMAIL_USER to your Gmail address
#    f. Set EMAIL_FROM to your Gmail address

# 2. VERIFY EMAIL CONFIGURATION:
#    npm start
#    Look for one of these messages in console:
#    ✅ Email Service: Gmail configured and verified
#    ✅ Email Service: Custom SMTP configured and verified
#    ⚠️  Email Service: Mock mode enabled (no credentials)

# 3. TEST EMAIL SERVICE:
#    Check /api/email/status endpoint:
#    curl http://localhost:5000/api/email/status

# 4. CUSTOM SMTP SETUP:
#    a. Get SMTP details from your provider
#    b. Set EMAIL_PROVIDER=custom
#    c. Fill in EMAIL_HOST, EMAIL_PORT, EMAIL_USER, EMAIL_PASSWORD

# ═══════════════════════════════════════════════════════════════
# IMPORTANT NOTES
# ═══════════════════════════════════════════════════════════════

# ⚠️  DO NOT commit .env file to version control (already in .gitignore)
# ⚠️  For Gmail, use App Password, not your main password
# ⚠️  Keep JWT_SECRET secret and change in production
# ✅ Email service will auto-fall back to mock mode if credentials are invalid
# ✅ Mock mode logs email content to console for testing

